aws_region = "us-east-1"

# Restrict access in non-dev environments.
# allowed_cidr_blocks = ["203.0.113.10/32"]
# streamlit_allowed_cidr_blocks = ["203.0.113.10/32"]
# publicly_accessible = false

# Streamlit ECS service (requires publicly_accessible = true for a task public IP).
